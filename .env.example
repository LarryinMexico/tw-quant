# ===========================================================
# 台股 ML 量化選股系統 — 環境變數設定範本
# ===========================================================
# 使用方式：
#   cp .env.example .env
#   然後填入你自己的 Token，不要把 .env 上傳到 GitHub！
# ===========================================================

# --- FinMind API（資料來源，必填）---
# 申請免費帳號：https://finmindtrade.com/
FINMIND_API_TOKEN=your_finmind_api_token_here

# --- FinLab API（選填）---
FINLAB_API_TOKEN=your_finlab_api_token_here

# --- LINE 通知（選填）---
# 不填則跳過每日推播，系統仍可正常運作
# LINE Channel Access Token 申請：https://developers.line.biz/
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_USER_ID=your_line_user_id_here
